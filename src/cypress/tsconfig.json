{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es6",
    "lib": [
      "es6",
      "dom"
    ],
    "types": [
      "cypress",
      "node"
    ],
    "noEmit": true,
    "isolatedModules": false,
    "typeRoots": [
      "../../node_modules/@types"
    ],
    "paths": {
      "@/*": [
        "../../src/*"
      ]
    },
  },
  "include": [
    "**/*.cy.ts",
    "**/*.ts"
  ],
  "exclude": []
}