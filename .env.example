# --- Client side variables ---
# These variables must be in next.config.js
API_URL= # Backend URL
MEDIA_URL= # Bucket URL

CLARITY_ID=

IS_PRODUCTION=


# --- Server side variables ---

# Only use these variables if you are using the auth flow
AUTH_SECRET= # Secret for JWT
AUTH_DEFAULT_USER= # Default user for auth flow
AUTH_DEFAULT_PASSWORD= # Default password for auth flow
MAILSLURP_API_KEY= # MailSlurp API Key

# Only use these variables if you are using Strapi as a headless CMS
SENTRY_AUTH_TOKEN=
STRAPI_URL=
STRAPI_MEDIA_URL=